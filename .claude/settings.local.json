{
  "permissions": {
    "allow": [
      "Read(//usr/local/bin/**)",
      "Read(//opt/**)",
      "Read(//home/vscode/**)",
      "Bash(apt list *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(gh auth *)",
      "Bash(git config *)",
      "Bash(git --version)",
      "Bash(curl --version)",
      "Bash(curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg)",
      "Bash(sudo dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg)",
      "Bash(sudo chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg)",
      "Bash(dpkg --print-architecture)",
      "Bash(echo \"deb [arch=$\\(dpkg --print-architecture\\) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main\")",
      "Bash(sudo tee /etc/apt/sources.list.d/github-cli.list)",
      "Bash(sudo apt-get update -q)",
      "Bash(sudo apt-get install -y gh)",
      "Bash(gh repo *)",
      "Bash(git push *)",
      "Bash(gh api *)",
      "Bash(npm list *)",
      "Bash(npm install *)",
      "Bash(sudo apt-get install -y nodejs npm)",
      "Bash(sudo npm install -g vercel)",
      "Bash(vercel *)",
      "Bash(gh secret *)"
    ]
  }
